# 数据库配置
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/medicine_db
NEO4J_URI=bolt://localhost:7687/medicine
NEO4J_USER=neo4j
NEO4J_PASSWORD=root

# Redis 缓存配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=  # 如果没有密码请留空
REDIS_ENABLED=true  # 是否启用Redis缓存（false则使用内存缓存）
CACHE_DEFAULT_TTL=3600  # 默认缓存时间（秒）
CACHE_KEY_PREFIX=tcm:  # 缓存键前缀

# AI配置
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
OPENAI_API_KEY=your_openai_api_key_here  # 可选

# 应用配置
DEBUG=True